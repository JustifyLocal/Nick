# Ted Sink Law Voice Receptionist AI - Environment Configuration

# Application Settings
APP_NAME="Ted Sink Law Voice Receptionist AI"
APP_VERSION="1.0.0"
DEBUG=false

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ted_sink_law

# Voice Settings
VOICE_ID=21m00Tcm4TlvDq8ikWAM
VOICE_STABILITY=0.5
VOICE_SIMILARITY_BOOST=0.75

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Security
SECRET_KEY=your_secret_key_here
ALLOWED_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# File Storage
TEMP_DIR=/tmp
AUDIO_STORAGE_PATH=/tmp/audio_files

# Monitoring and Logging
LOG_FILE_PATH=/var/log/ted_sink_law_ai.log
METRICS_ENABLED=true

# External Services
WHISPER_MODEL=base
ELEVENLABS_MODEL=eleven_monolingual_v1

# Conversation Settings
MAX_CONVERSATION_TURNS=20
CONVERSATION_TIMEOUT_MINUTES=30

# Lead Qualification
MIN_DAMAGES_THRESHOLD=5000.0
STATUTE_OF_LIMITATIONS_YEARS=3

# Firm Information (for reference - these are also in settings.py)
FIRM_NAME="Ted Law: Accident & Injury Law Firm, LLC"
FIRM_FOUNDED=2019
FOUNDER="Ted Sink"
SERVICE_STATES=["South Carolina", "Georgia"]
TIMEZONE="America/New_York"

# Office Information
PRIMARY_OFFICE_ADDRESS="1075-A E Montague Ave"
PRIMARY_OFFICE_PHONE="(843) 800-0000"

# Service Standards
CONSULTATION_FREE=true
CONTINGENCY_FEE=true
SATISFACTION_GUARANTEE_DAYS=30
SAME_DAY_RESPONSE=true
AVAILABILITY_24_7=true

# Brand Keywords
BRAND_KEYWORDS=["next-generation law firm", "21st century technology", "we won't back down from a fight", "no fee unless we win", "David vs. Goliath", "personal attention", "rapid response", "modern tools"]

# Emergency Keywords
EMERGENCY_KEYWORDS=["emergency", "urgent", "hospital", "severe injury", "life-threatening", "immediate", "critical"]

# Practice Areas
PRACTICE_AREAS=["Car Accidents", "Truck Accidents", "Motorcycle Accidents", "Workers' Compensation", "Wrongful Death", "Premises Liability", "Ride-share Accidents", "Medical Malpractice", "Nursing Home Abuse", "Slip and Fall", "Construction Accidents"]

# Disqualifying Cases
DISQUALIFYING_CASES=["Criminal Law", "Family Law", "Business Law", "Real Estate", "Estate Planning", "Bankruptcy", "Immigration"]

# Office Locations
OFFICE_NORTH_CHARLESTON_NAME="North Charleston"
OFFICE_NORTH_CHARLESTON_ADDRESS="1075-A E Montague Ave"
OFFICE_NORTH_CHARLESTON_PHONE="(843) 800-0000"
OFFICE_NORTH_CHARLESTON_PRIMARY=true

OFFICE_GREENVILLE_NAME="Greenville"
OFFICE_GREENVILLE_ADDRESS="Greenville Office"
OFFICE_GREENVILLE_PHONE="(864) 800-0000"

OFFICE_MYRTLE_BEACH_NAME="Myrtle Beach"
OFFICE_MYRTLE_BEACH_ADDRESS="Myrtle Beach Office"
OFFICE_MYRTLE_BEACH_PHONE="(843) 800-0000"

OFFICE_COLUMBIA_NAME="Columbia"
OFFICE_COLUMBIA_ADDRESS="Columbia Office"
OFFICE_COLUMBIA_PHONE="(803) 800-0000"

OFFICE_AIKEN_NAME="Aiken"
OFFICE_AIKEN_ADDRESS="Aiken Office"
OFFICE_AIKEN_PHONE="(803) 800-0000"

OFFICE_ATLANTA_NAME="Atlanta"
OFFICE_ATLANTA_ADDRESS="Atlanta Office"
OFFICE_ATLANTA_PHONE="(404) 800-0000"

# Development Settings
ENVIRONMENT=development
ENABLE_DEBUG_ENDPOINTS=false
ENABLE_TEST_DATA=false

# Performance Settings
MAX_AUDIO_FILE_SIZE_MB=50
AUDIO_FORMATS=["wav", "mp3", "m4a"]
MAX_CONCURRENT_CONVERSATIONS=100

# Backup and Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Integration Settings
ENABLE_SMS_INTEGRATION=false
ENABLE_EMAIL_INTEGRATION=false
ENABLE_CALENDAR_INTEGRATION=false

# Analytics and Reporting
ANALYTICS_ENABLED=true
REPORTING_SCHEDULE="0 6 * * 1"  # Weekly on Monday at 6 AM